{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx prettier --write $file_path"
                    },
                    {
                        "type": "command",
                        "command": "npx tsc --noEmit"
                    }
                ]
            }
        ]
    }
}